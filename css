  padding: 8px 12px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  color: #dce9ff;
  font-size: 0.85rem;
  transition: transform 220ms ease, background 220ms ease;
}

.cart-badge.is-bumping {
  animation: badgePop 420ms ease;
  background: rgba(236, 230, 31, 0.18);
}

.cart-items {
  display: grid;
  gap: 12px;
  margin: 20px 0;
}

.cart-empty,
.cart-note {
  margin: 0;
  color: var(--muted);
}

.cart-item {
  padding: 14px 16px;
  border: 1px solid var(--line);
  border-radius: 18px;
  background: rgba(5, 14, 27, 0.75);
  transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
}

.cart-item strong {
  display: block;
  font-size: 1rem;
}

.cart-item button {
  border: 0;
  color: #ffb8bd;
  background: transparent;
  cursor: pointer;
  font: inherit;
}

.cart-summary {
  display: grid;
  gap: 18px;
  padding-top: 18px;
  border-top: 1px solid var(--line);
}

.admin-shell {
  padding-bottom: 60px;
}

.is-hidden {
  display: none;
}

.admin-grid {
  grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.8fr);
}

.admin-main {
  margin-top: 28px;
}

.admin-form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.admin-menu-list {
  display: grid;
  gap: 16px;
}

.admin-menu-item {
  position: relative;
  padding: 18px;
  isolation: isolate;
  box-shadow: 0 0 calc(8px + (var(--kick-flash) * 18px)) rgba(36, 64, 255, calc(0.02 + (var(--kick-flash) * 0.12)));
}

.admin-menu-head,
.admin-item-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
}

.admin-menu-head {
  margin-bottom: 14px;
}

.admin-menu-item h3 {
  margin: 10px 0 0;
  font: 700 1.6rem "Rajdhani", sans-serif;
}

.admin-menu-item label,
.admin-editor-card label,
.admin-login-form label {
  display: grid;
  gap: 10px;
  margin-top: 12px;
  font-weight: 500;
}

.danger-btn {
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(255, 156, 147, 0.35);
  border-radius: 999px;
  padding: 14px 22px;
  color: #ffd2cd;
  background: rgba(255, 59, 48, 0.12);
  font: 700 0.95rem "Space Grotesk", sans-serif;
  cursor: pointer;
  transition: transform 220ms ease, box-shadow 220ms ease, background 220ms ease;
}

.delivery-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
}

.delivery-btn {
  position: relative;
  overflow: hidden;
  display: inline-flex;
  justify-content: center;
  align-items: center;
  min-height: 52px;
  border-radius: 18px;
  text-decoration: none;
  color: #07111f;
  font-weight: 700;
  transition: transform 220ms ease, box-shadow 220ms ease;
}

body.bass-hit {
  --kick-flash: 1;
  --kick-border: rgba(236, 230, 31, 0.46);
  --kick-shadow:
    0 24px 76px rgba(0, 0, 0, 0.52),
    0 0 26px rgba(236, 230, 31, 0.18),
    0 0 54px rgba(255, 59, 48, 0.14);
}

.spin-once {
  animation: quickSpin 420ms ease;
}

.is-pulsing {
  animation: panelPulse 520ms ease;
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation: none !important;
    transition: none !important;
    scroll-behavior: auto !important;
  }

  .section[data-animate],
  .menu-card[data-animate-item],
  .feature-list article[data-animate-item],
  .cart-item[data-animate-item],
  .location-card[data-animate-item],
  .order-form[data-animate-item],
  .cart-panel[data-animate-item],
  .hero-copy > *,
  .hero-card {
    opacity: 1 !important;
    transform: none !important;
  }

  .hero,
  .section,
  .cursor-orb,
  .cursor-dot,
  .cursor-spark,
  .cursor-wave,
  .scroll-progress-bar::after,
  .stats article,
  .hero-card,
  .hero-orb,
  .hero-particle,
  .hero-petal,
  .hero-sparkle,
  .hero-comet,
  .hero-energy-ring,
  .hero-neon-dot,
  .hero-magic-slash,
  .hero-magic-card,
  .hero-speedlines,
  .hero-scanline,
  .hero-float-badge,
  .anime-sticker,
  .chibi-sticker,
  .chibi-eye,
  .live-strip-track,
  .section-heading::before,
  .section-tag::before,
  .location-map-shell::before,
  .location-map-shell::after,
  .location-map-pin,
  .location-map-pin::after,
  .order-form::before,
  .order-form::after,
  .menu-card,
  .feature-list article,
  .order-form,
  .location-card,
  .login-copy,
  .admin-login-form,
  .admin-editor-card,
  .admin-list-card,
  .admin-menu-item,
  .cart-panel,
  .music-widget {
    animation: none !important;
  }

  .menu-card::after,
  .feature-list article::before,
  .location-card::before,
  .section-heading::before {
    display: none !important;
  }
}

.delivery-btn.gojek {
  background: linear-gradient(135deg, #36d27d, #a8ffd0);
}

.delivery-btn.grab {
  background: linear-gradient(135deg, #00b14f, #9affc6);
}

@media (max-width: 960px) {
  .hero-grid,
  .spotlight,
  .minigame-layout,
  .location-grid,
  .checkout-layout,
  .menu-grid,
  .admin-login-grid,
  .admin-panel-grid,
  .admin-grid {
    grid-template-columns: 1fr 1fr;
  }

  .hero-radar-panel {
    position: relative;
    top: auto;
    right: auto;
    width: 100%;
    margin-top: 24px;
  }

  .breaking-news-panel {
    position: relative;
    top: auto;
    left: auto;
    right: auto;
    width: 100%;
    margin: 0 0 24px;
  }

  .hero-right-fill {
    position: relative;
    top: auto;
    right: auto;
    bottom: auto;
    width: 100%;
    min-height: auto;
    margin: 0 0 24px;
    pointer-events: auto;
  }

  .hero-copy {
    max-width: 100%;
  }

  .hero {
    min-height: auto;
  }
}

@media (min-width: 961px) and (max-width: 1280px) {
  .hero-right-fill {
    position: relative;
    top: auto;
    right: auto;
    bottom: auto;
    width: 100%;
    min-height: auto;
    margin: 0 0 24px;
    pointer-events: auto;
  }
}

@media (max-width: 720px) {
  .page-shell {
    width: calc(100% - 20px);
    padding-top: 10px;
  }

  .hero,
  .section {
    padding: 20px;
    border-radius: 22px;
  }

  .topbar,
  .hero-grid,
  .spotlight,
  .minigame-layout,
  .location-grid,
  .checkout-layout,
  .menu-grid,
  .admin-login-grid,
  .admin-panel-grid,
  .admin-grid,
  .admin-form-row {
    grid-template-columns: 1fr;
  }

  .topbar {
    gap: 18px;
  }

  .location-map-shell,
  .location-map-frame {
    min-height: 300px;
  }

  .brand {
    align-items: flex-start;
  }

  .brand-logo {
    width: 72px;
    height: 72px;
  }

  .hero-copy h2 {
    max-width: 100%;
  }

  .hero-right-fill {
    grid-template-rows: auto;
  }

  .side-food-visual {
    min-height: 250px;
  }

  .side-food-plate {
    width: 170px;
    height: 170px;
  }

  .side-food-bowl {
    left: 45px;
    top: 59px;
    width: 100px;
    height: 78px;
  }

  .food-slider {
    width: 100%;
    margin-top: 16px;
  }

  .hero-float-badge {
    font-size: 0.66rem;
  }

  .anime-sticker-row {
    gap: 10px;
  }

  .anime-sticker-stage {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .food-slider {
    min-height: 250px;
  }

  .food-slide {
    grid-template-columns: 1fr;
    align-content: center;
    justify-items: start;
    gap: 12px;
  }

  .food-plate {
    width: 96px;
    height: 96px;
  }

  .food-slide b {
    position: absolute;
    top: 18px;
    right: 18px;
  }

  .food-slider-dots {
    left: 24px;
  }

  .anime-sticker {
    width: 74px;
    height: 74px;
  }

  .chibi-sticker {
    min-height: 138px;
    padding: 11px 8px;
  }

  .chibi-head {
    width: 64px;
    height: 64px;
  }

  .chibi-hair {
    left: 4px;
    width: 56px;
    height: 30px;
  }

  .chibi-eye {
    top: 33px;
  }

  .chibi-eye-left {
    left: 18px;
  }

  .chibi-eye-right {
    right: 18px;
  }

  .chibi-mouth {
    top: 50px;
  }

  .badge-left,
  .badge-right {
    right: 18px;
    left: auto;
  }

  .badge-left {
    bottom: 22px;
  }

  .badge-top {
    top: 12px;
    right: 18px;
  }

  .badge-right {
    bottom: 76px;
  }

  .stats article,
  .menu-card,
  .feature-list article,
  .location-card,
  .order-form,
  .cart-panel,
  .login-copy,
  .admin-login-form,
  .admin-editor-card,
  .admin-list-card,
  .admin-menu-item {
    border-radius: 20px;
  }

  .primary-btn,
  .secondary-btn,
  .cta-link,
  .add-cart-btn,
  .danger-btn,
  .delivery-btn,
  .order-form button,
  .music-toggle {
    width: 100%;
    text-align: center;
  }

  .delivery-buttons {
    grid-template-columns: 1fr;
  }

  .music-widget {
    left: 10px;
    right: 10px;
    bottom: 10px;
    justify-content: space-between;
  }
}

@media (max-width: 560px) {
  .topbar,
  .topbar-actions,
  .hero-actions,
  .minigame-actions,
  .admin-ai-actions,
  .stats,
  .minigame-stats,
  .minigame-build-tools,
  .menu-card-footer,
  .cart-header,
  .cart-row,
  .cart-summary > div:first-child,
  .location-meta,
  .admin-menu-head,
  .admin-item-actions,
  .music-widget {
    grid-template-columns: 1fr;
    align-items: stretch;
  }

  .location-map-head,
  .location-meta {
    flex-direction: column;
    align-items: flex-start;
  }

  .topbar-actions,
  .hero-actions,
  .minigame-actions,
  .admin-ai-actions,
  .stats,
  .admin-item-actions {
    gap: 12px;
  }

  .brand h1 {
    font-size: 1.6rem;
  }

  .hero-copy h2,
  .section-heading h2,
  .spotlight-copy h2 {
    line-height: 1;
  }

  .hero-copy h2 {
    font-size: clamp(2.35rem, 12vw, 3.5rem);
  }

  .side-menu-card {
    align-items: flex-start;
    flex-direction: column;
  }

  .side-food-visual {
    grid-template-columns: 1fr;
    min-height: 330px;
    justify-items: center;
    text-align: center;
  }

  .side-food-plate {
    grid-column: 1;
    grid-row: 1;
    transform: none;
  }

  .side-food-visual > div {
    grid-column: 1;
    grid-row: 2;
    justify-items: center;
    margin-top: 12px;
    max-width: 100%;
    padding-top: 0;
  }

  .side-food-points li {
    text-align: left;
  }

  .side-mini-grid {
    grid-template-columns: 1fr;
  }

  .anime-sticker-row {
    display: flex;
    justify-content: center;
  }

  .anime-sticker-stage {
    grid-template-columns: 1fr;
  }

  .anime-sticker {
    width: 68px;
    height: 68px;
  }

  .stats article {
    min-width: 0;
  }

  .live-strip-track {
    gap: 22px;
    padding: 11px 0;
  }

  .live-strip-track span {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
  }

  .menu-card-footer strong,
  .cart-summary strong,
  .location-meta strong,
  .admin-menu-head strong {
    word-break: break-word;
  }

  .location-address,
  .lead,
  .spotlight-copy p,
  .menu-card p,
  .feature-list span,
  .form-note {
    line-height: 1.6;
  }

  .music-widget {
    gap: 10px;
    padding: 12px;
    width: calc(100vw - 20px);
  }

  .music-widget-copy {
    text-align: left;
    min-width: 0;
  }
}
